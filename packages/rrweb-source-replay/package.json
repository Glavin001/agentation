{
  "name": "@agentation/rrweb-source-replay",
  "version": "0.1.0",
  "description": "rrweb ReplayPlugin that maintains a source map store during playback",
  "license": "PolyForm-Shield-1.0.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "dev": "pnpm build && pnpm watch"
  },
  "dependencies": {
    "@agentation/rrweb-source-record": "workspace:*"
  },
  "peerDependencies": {
    "rrweb": ">=2.0.0-alpha.0"
  },
  "devDependencies": {
    "rrweb": "^2.0.0-alpha.20",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
