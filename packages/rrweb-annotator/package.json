{
  "name": "@glavin001/rrweb-annotator",
  "version": "0.1.0",
  "description": "Agentation annotation adapter for rrweb player replay",
  "license": "PolyForm-Shield-1.0.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "dev": "pnpm build && pnpm watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentation/rrweb-source-replay": "workspace:@glavin001/rrweb-source-replay@*",
    "agentation": "workspace:@glavin001/agentation@*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "rrweb": ">=2.0.0-alpha.0",
    "rrweb-player": ">=2.0.0-alpha.0"
  },
  "peerDependenciesMeta": {
    "rrweb-player": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rrweb": "^2.0.0-alpha.20",
    "rrweb-player": "^2.0.0-alpha.20",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
